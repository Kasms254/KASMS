# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyw
.Python
*.egg-info/
dist/
build/
.eggs/
.coverage
htmlcov/
.pytest_cache/

# Virtual environments
venv/
.venv/
env/
ENV/

# Django
db.sqlite3
*.sqlite3
media/
staticfiles/
logs/
*.log

# Celery
celerybeat-schedule.*

# Migrations cache only (migration files MUST be tracked)
core/migrations/__pycache__/

# Environment / secrets (NEVER commit these)
.env
.env.*
!.env.example

# Database dumps
*.dump
*.sql
*.sql.gz
backup.json
datadump.json

# SSL certificates (server-specific, generated on server)
certbot/

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.env
node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# Claude Code
CLAUDE.md

# Developer handover docs (shared separately)
DOCKER_MIGRATION.md

# One-off / legacy files
find_old_references.sh
fix_all.py
debug_jass_jwt.py
jitsi_private.pk
jaas_private.pem
jaas_public.pem
BIOMETRIC_SETUP.md
